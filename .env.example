# Required
OPENAI_API_KEY=sk-your-openai-api-key

# Optional — weather forecasts (planner skips weather if unset)
OPENWEATHER_API_KEY=

# Recommended — required by Nominatim and Wikipedia API etiquette
NOMINATIM_USER_AGENT=RoadtripPlanner/1.0 (you@example.com)

# Optional — LangSmith agent tracing
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=Roadtrip_Planner

# Optional — POI provider (defaults to OpenStreetMap)
POI_PROVIDER=osm
# GOOGLE_PLACES_API_KEY=

# Optional — defaults shown below (uncomment to override)
# OPENAI_MODEL=gpt-4o-mini
# OSRM_BASE_URL=https://router.project-osrm.org
# NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# WIKIPEDIA_API_URL=https://en.wikipedia.org/w/api.php
# OVERPASS_API_URL=https://overpass-api.de/api/interpreter
# OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5
